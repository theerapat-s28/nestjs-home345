generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//================ ENUMS =================//

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  INFO     // General news or announcements
  TASK     // Task / work assignments
  EVENT    // Calendar event invitations
  APPROVAL // Approval requests (e.g. content, access)
  SYSTEM   // System-generated messages
}

// ISO 4217 currency codes — extend as needed
enum Currency {
  USD
  EUR
  THB
}

//================ USERS =================//

model User {
  id              String     @id @default(uuid())
  username        String     @unique
  email           String     @unique
  password        String?
  isResetPassword Boolean    @default(true)
  role            Role       @default(USER)
  status          UserStatus @default(PENDING)
  lastLoginAt     DateTime?  @db.Timestamptz

  // Access
  hasHome345Access Boolean   @default(false)      // allow user to access home345 module

  // Timestamps
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  // Relations
  profile                UserProfile?
  sentNotifications      Notification[]
  notificationRecipients NotificationRecipient[]
  subscriptions          Subscription[]
  paymentMethods         PaymentMethod[]
  portfolios             PortfolioMember[]

  @@index([deletedAt])
  @@map("users")
}

//================ USER PROFILE =================//

// Frontend theme
enum Theme {
  ROOT        // Default theme
  DEEP_NIGHT  // Dark theme
}

model UserProfile {
  id              String  @id @default(uuid())
  name            String?
  profileImageUrl String?
  bio             String? // Short personal bio / description
  userId          String  @unique
  theme           Theme   @default(ROOT)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

//================ DOCUMENTS =================//

/**
 * Generic document record.  The S3 key is stored here; the actual file
 * lives in S3.  Attach documents to any entity via DocumentLink.
 */
model Document {
  id          String  @id @default(uuid())
  name        String
  key         String  @unique // S3 object key
  description String?
  mimeType    String? // e.g. "application/pdf"

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  // Relations
  links DocumentLink[]

  @@map("documents")
}

/**
 * Polymorphic join table: attaches a Document to any entity.
 *
 * Add new entity types to DocumentEntityType as your project grows.
 * Example: add `item`, `post`, `report` etc.
 */
enum DocumentEntityType {
  USER_PROFILE
  OTHER
}

model DocumentLink {
  documentId String
  entityId   String
  entityType DocumentEntityType

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([documentId, entityId, entityType])
  @@index([entityId, entityType])
  @@map("document_links")
}

//================ NOTIFICATIONS =================//

model Notification {
  id       String           @id @default(uuid())
  title    String
  message  String?
  type     NotificationType
  data     Json?            // Arbitrary metadata — use for deep-link payloads etc.
  senderId String?

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  // Relations
  sender     User?                   @relation(fields: [senderId], references: [id], onDelete: SetNull)
  recipients NotificationRecipient[]

  @@index([senderId])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationRecipient {
  id             String @id @default(uuid())
  userId         String
  notificationId String

  isRead Boolean   @default(false)
  readAt DateTime? @db.Timestamptz

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
  @@index([notificationId])
  @@index([userId, isRead])
  @@map("notification_recipients")
}

// =============================================================
// SUBSCRIPTION REMINDER MODULE
// =============================================================

enum BillingCycle {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum PaymentType {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  BANK_TRANSFER
  CRYPTO
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
}



model Subscription {
  id          String  @id @default(uuid())
  userId      String
  name        String  @unique // Netflix, Spotify, AWS, etc.
  description String? // Optional note
  isActive    Boolean @default(true)

  // --- Billing ---
  amount          Decimal      @db.Decimal(10, 2) // Use Decimal, not Float (avoids rounding errors)
  currency        Currency     @default(THB) // Enum-guarded, prevents "usd" / "USD" drift
  billingCycle    BillingCycle
  nextBillingDate DateTime     @db.Timestamptz // Source of truth for reminder scheduling

  // --- Payment ---
  paymentMethodId String?
  
  // --- Auto Timestamps ---
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  // --- Relation ---
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  reminders Reminder[]

  // Indexes for common query patterns
  @@index([nextBillingDate]) // Reminder job: WHERE nextBillingDate <= now() + N days
  @@index([userId, isActive]) // Dashboard: fetch user's active subscriptions
  @@index([deletedAt])
  @@map("subscriptions")
}

model PaymentMethod {
  id       String @id @default(uuid())
  userId   String
  type     PaymentType
  provider String? // VISA, Mastercard, etc.
  last4    String? // Last 4 digits only — never store full card numbers
  name     String? // "My main card"
  
  // --- Auto Timestamps ---
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  // --- Relation ---
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([deletedAt])
  @@map("payment_methods")
}

model Reminder {
  id             String       @id @default(uuid())
  subscriptionId String
  daysBefore Int // e.g. 3 = remind 3 days before nextBillingDate
  channel    NotificationChannel // How to deliver the reminder

  // --- Delivery tracking ---
  isSent Boolean   @default(false) // Prevents duplicate sends
  sentAt DateTime? @db.Timestamptz // Null until actually delivered

  createdAt DateTime @default(now()) @db.Timestamptz

  // --- Relation ---
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // A subscription should have at most one reminder rule per (daysBefore + channel) combo
  @@unique([subscriptionId, daysBefore, channel])
  @@index([isSent]) // Reminder job: WHERE isSent = false AND ...
  @@map("reminders")
}

//=============================================================
// PORTFOLIO & ASSET MODULE
//=============================================================

//////////////////////////////////////////////////////
// 📁 PORTFOLIO (can be shared)
//////////////////////////////////////////////////////

model Portfolio {
  id           String   @id @default(uuid())
  name         String
  description  String?
  baseCurrency Currency @default(THB) // [#9] base currency for equity rollup

  // --- Relations ---
  members      PortfolioMember[]
  assets       PortfolioAsset[]
  cashAccounts PortfolioCash[]
  cashTxns     CashTransaction[]

  // --- Timestamps ---
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  @@index([deletedAt])
  @@map("portfolios")
}

model PortfolioMember {
  id          String        @id @default(uuid())
  userId      String
  portfolioId String
  role        PortfolioRole @default(VIEWER)
  status      MemberStatus  @default(PENDING)

  // --- Relations ---
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  // --- Timestamps ---
  createdAt   DateTime @default(now()) @db.Timestamptz

  @@unique([userId, portfolioId])
  @@map("portfolio_members")
}

enum PortfolioRole {
  OWNER
  EDITOR
  VIEWER
}

enum MemberStatus {
  PENDING     // invited but not accepted
  ACTIVE
  REVOKED
}

//////////////////////////////////////////////////////
// 🪙 ASSET (global definition)
//////////////////////////////////////////////////////

model Asset {
  id        String    @id @default(uuid())
  symbol    String    // BTC, AAPL, XAU
  name      String    // Bitcoin, Apple, Gold
  type      AssetType

  // --- Relations ---
  prices    AssetPrice[]
  holdings  PortfolioAsset[]

  // --- Timestamps ---
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  @@unique([symbol, type])
  @@index([type]) // [#10] filter by asset type efficiently
  @@index([deletedAt])
  @@map("assets")
}

enum AssetType {
  STOCK
  CRYPTO
  GOLD
  FUTURES
  FOREX
  OTHER
}

//////////////////////////////////////////////////////
// 💰 PRICE HISTORY
//////////////////////////////////////////////////////

model AssetPrice {
  id         String   @id @default(uuid())
  assetId    String
  price      Decimal  @db.Decimal(20, 8) 
  currency   Currency @default(THB)
  source     String?  // [#5] "binance", "yahoo", "manual", etc.
  recordedAt DateTime @default(now()) @db.Timestamptz

  // --- Relations ---
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, recordedAt])
  @@index([currency, recordedAt]) // [#10] multi-currency price lookups
  @@map("asset_prices")
}

//////////////////////////////////////////////////////
// 📊 PORTFOLIO HOLDING (cached state)
//////////////////////////////////////////////////////

model PortfolioAsset {
  id          String   @id @default(uuid())
  portfolioId String
  assetId     String

  // cached values (derived from transactions)
  quantity    Decimal  @default(0) @db.Decimal(20, 8)
  avgCost     Decimal  @default(0) @db.Decimal(20, 8)

  // [#4] cache safety — detect stale state and prevent recalc races
  lastRecalculatedAt DateTime? @db.Timestamptz
  isRecalculating    Boolean   @default(false)

  // --- Relations ---
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  // --- Timestamps ---
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  @@unique([portfolioId, assetId])
  @@index([deletedAt])
  @@map("portfolio_assets")
}

//////////////////////////////////////////////////////
// 🔄 TRANSACTIONS (source of truth)
//////////////////////////////////////////////////////

model Transaction {
  id               String          @id @default(uuid())
  portfolioAssetId String
  type             TransactionType

  quantity         Decimal         @db.Decimal(20, 8)
  pricePerUnit     Decimal         @db.Decimal(20, 8)
  currency         Currency        @default(THB) // [#3] USD, THB — currency of the quoted price
  
  fee              Decimal?        @db.Decimal(20, 8) // optional trading fee
  note             String?
  executedAt       DateTime        @db.Timestamptz

  // --- Relations ---
  portfolioAsset   PortfolioAsset  @relation(fields: [portfolioAssetId], references: [id], onDelete: Cascade)
  cashTransaction  CashTransaction?

  // --- Timestamps ---
  createdAt        DateTime @default(now()) @db.Timestamptz

  @@index([portfolioAssetId, executedAt])
  @@map("transactions")
}

enum TransactionType {
  BUY
  SELL
  TRANSFER_IN   // [#6] asset transferred in from external wallet/broker
  TRANSFER_OUT  // [#6] asset transferred out
  DIVIDEND      // [#6] cash or stock dividend received
  SPLIT         // [#6] stock split — quantity changes, cost basis does not
  FEE           // [#6] standalone fee/charge
}

//////////////////////////////////////////////////////
// 💵 CASH (balance per currency per portfolio)
//////////////////////////////////////////////////////

model PortfolioCash {
  id          String   @id @default(uuid())
  portfolioId String
  currency    Currency @default(THB)
  balance     Decimal  @default(0) @db.Decimal(20, 8)

  // --- Relations ---
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  // --- Timestamps ---
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@unique([portfolioId, currency])
  @@map("portfolio_cash")
}

//////////////////////////////////////////////////////
// 🧾 CASH TRANSACTIONS (audit trail) — [#1]
//////////////////////////////////////////////////////

model CashTransaction {
  id           String       @id @default(uuid())
  portfolioId  String
  currency     Currency     @default(THB)
  type         CashTxnType
  amount       Decimal      @db.Decimal(20, 8) // positive = money in, negative = money out

  // optional back-link to the trade that caused this cash movement
  relatedTxnId String?      @unique
  relatedTxn   Transaction? @relation(fields: [relatedTxnId], references: [id], onDelete: SetNull)

  note         String?
  executedAt   DateTime     @db.Timestamptz

  // --- Relations ---
  portfolio    Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  // --- Timestamps ---
  createdAt    DateTime @default(now()) @db.Timestamptz

  @@index([portfolioId, executedAt])
  @@index([currency, executedAt]) // [#10] per-currency cash flow queries
  @@map("cash_transactions")
}

enum CashTxnType {
  DEPOSIT      // cash added to portfolio
  WITHDRAWAL   // cash withdrawn
  BUY_DEBIT    // cash deducted when buying an asset
  SELL_CREDIT  // cash received when selling an asset
  DIVIDEND     // dividend payment received
  FEE          // fee charged
  TRANSFER     // internal transfer between portfolios
}

//=============================================================
// HOME345 BILL MODULE
//=============================================================

enum BillCategory {
  HOME_LOAN
  ELECTRIC
  WATER
  INTERNET
  OTHER
}

model Home345Bill {
  id          String   @id @default(uuid())
  seq         Int
  name        String
  date        DateTime? @db.Date

  isCompleted Boolean  @default(false)

  // --- Timestamps ---
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  // --- Relations ---
  billItems Home345BillItem[]

  @@index([date])
  @@map("home345_bills")
}

model Home345BillItem {
  id       String       @id @default(uuid())
  billId   String
  category BillCategory
  amount   Decimal      @db.Decimal(10, 2)
  date     DateTime? @db.Date
  isPaid   Boolean      @default(false)
  note     String?

  // --- Timestamps ---
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  // --- Relations ---
  bill Home345Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@map("home345_bill_items")
}

model Home345Transaction {
  id     String  @id @default(uuid())
  name   String
  amount Decimal @db.Decimal(10, 2)
  note   String?

  // --- Timestamps ---
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("home345_transactions")
}
