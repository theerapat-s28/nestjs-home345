# Environment variables for personal-nestjs-api
# Copy to `.env.development` or `.env.production` and replace all placeholder values.

# ─── Application ─────────────────────────────────────────────────────────────
# "development" or "production"
NODE_ENV="development"

# Set to "true" in development to skip JWT authentication (injects mock admin user)
BYPASS_AUTH="false"

# Display name shown in Swagger UI and startup logs
APP_NAME="My Personal API"

# Semantic version tag shown in Swagger and /api/version endpoint
APP_VERSION="1.0.0"

# Public URL of the backend (important for local file storage and email links)
BACKEND_URL="http://localhost:3000"
# Frontend origin allowed by CORS and used for OAuth redirects
FRONTEND_URL="http://localhost:4200"

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (pnpm migrate:dev to apply migrations)
DATABASE_URL="postgresql://root:password@localhost:5432/personal_db"

# ─── Authentication ───────────────────────────────────────────────────────────
# Strong random secret for signing JWT access tokens (min 32 chars)
JWT_SECRET="replace-with-a-strong-random-secret"

# AES-256 secret for API key encryption (exactly 32 chars, padded if shorter)
API_KEY_SECRET="replace-with-a-32-char-secret___"

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
# See `google.strategy.ts` for callback url used for google cloud setting.

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID="replace-with-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="replace-with-aws-secret-access-key"
AWS_S3_BUCKET="replace-with-s3-bucket-name"

# ─── Local Storage (Multer) ───────────────────────────────────────────────────
LOCAL_UPLOADS_DEST="uploads"

